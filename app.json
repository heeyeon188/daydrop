{
  "expo": {
    "name": "daydrop",
    "slug": "daydrop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "daydrop",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Daydrop uses the camera so you can take and share your daily photo.",
        "NSPhotoLibraryUsageDescription": "Daydrop uses your photo library so you can choose a daily photo to share.",
        "NSPhotoLibraryAddUsageDescription": "Daydrop saves photos only when you choose to save them.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.heeyeonkim112.daydrop"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Daydrop uses your photo library so you can choose a daily photo to share.",
          "cameraPermission": "Daydrop uses the camera so you can take and share your daily photo.",
          "microphonePermission": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Daydrop uses the camera so you can take and share your daily photo.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Daydrop uses your photo library so you can choose a daily photo to share.",
          "savePhotosPermission": "Daydrop saves photos only when you choose to save them.",
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-notifications",
      "expo-font",
      "expo-image",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4bbf1d8c-1d3e-4e72-9417-e7022119fc58"
      }
    },
    "owner": "heeyeonkim112"
  }
}
